# Copy this file to .env and fill in the values before running the app.
# Never commit .env to version control.

# Flask secret key — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# MySQL connection string
# Local:  mysql+pymysql://root:@localhost/agora_db
# AWS RDS: mysql+pymysql://<user>:<password>@<rds-endpoint>:3306/agora
DATABASE_URL=mysql+pymysql://root:@localhost/agora_db
